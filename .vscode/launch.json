{
    "version": "0.2.0",
    "configurations": [
        
        
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Run Tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                   "${file}",
                 "-v",
               "-s"
                 ],
           "console": "integratedTerminal",
          "justMyCode": true
        }
    ]
}